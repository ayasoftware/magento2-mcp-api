    </route>
    <route url="/V1/mg_seo_update_meta_description" method="POST">
        <service class="Ayasoftware\McpApi\Api\SeoManagementInterface" method="updateMetaDescription"/>
        <resources>
            <resource ref="Ayasoftware_McpApi::seo"/>
