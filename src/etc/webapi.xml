    </route>
    <route url="/V1/mg_seo_update_meta_title" method="POST">
        <service class="Ayasoftware\McpApi\Api\SeoManagementInterface" method="updateMetaTitle"/>
        <resources>
            <resource ref="Ayasoftware_McpApi::seo"/>
