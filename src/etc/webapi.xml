        </resources>
    </route>
    <route url="/V1/mg_indexer_status/:indexerId" method="GET">
        <service class="Ayasoftware\McpApi\Api\IndexerManagementInterface" method="statusById"/>
        <resources>
            <resource ref="Ayasoftware_McpApi::indexer"/>
        </resources>
    </route>
    <route url="/V1/mg_coupon/:couponId" method="PUT">
        <service class="Ayasoftware\McpApi\Api\CouponManagementInterface" method="updateCoupon"/>
        <resources>
            <resource ref="Ayasoftware_McpApi::coupon"/>
        </resources>
    </route>
    <route url="/V1/mg_seo_audit_product/:sku" method="GET">
        <service class="Ayasoftware\McpApi\Api\SeoManagementInterface" method="auditProduct"/>
